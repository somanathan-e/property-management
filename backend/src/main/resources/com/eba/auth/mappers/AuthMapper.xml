<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eba.auth.mappers.AuthMapper">
    <select id="findByUsername" parameterType="string" resultType="com.eba.auth.domain.AuthenticatedUser">
        SELECT 1 AS userId, #{username} AS username, 'ADMIN' AS role
        WHERE #{username} IN ('admin', 'leasing.manager', 'ops.user')
    </select>
</mapper>
